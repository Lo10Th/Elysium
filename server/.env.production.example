# Production Environment Variables for Vercel Deployment
# Copy this to .env.production and fill in your values
# Then set these in Vercel Dashboard: https://vercel.com/dashboard

# =============================================================================
# SUPABASE CONFIGURATION (Required)
# =============================================================================

# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Public anonymous key (safe for client-side)
# In Supabase Dashboard: Settings > API > Project API keys > anon public
SUPABASE_KEY=your-anon-key-here

# Service role key (secret - server-side only!)
# In Supabase Dashboard: Settings > API > Project API keys > service_role
# ⚠️ WARNING: Keep this secret! Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# APPLICATION SETTINGS (Optional - defaults provided)
# =============================================================================

# Application name (default: Elysium Registry)
APP_NAME=Elysium Registry

# Application version (default: 1.0.0)
APP_VERSION=1.0.0

# Enable debug mode (default: false)
# Set to true for development, false for production
DEBUG=false

# =============================================================================
# CORS SETTINGS (Optional)
# =============================================================================

# Allow these origins to access the API
# Use comma-separated list: https://example.com,https://another.com
# Default: "*" (all origins)
CORS_ORIGINS=*

# =============================================================================
# RATE LIMITING (Optional)
# =============================================================================

# Max requests per IP per window (default: 100)
RATE_LIMIT_REQUESTS=100

# Window size in seconds (default: 60)
RATE_LIMIT_WINDOW=60

# =============================================================================
# CUSTOM DOMAIN (Optional)
# =============================================================================

# If using custom domain, set this for CORS
# DOMAIN=ely.karlharrenga.com

# =============================================================================
# DEPLOYMENT TIPS
# =============================================================================

# 1. Create a Supabase account at https://supabase.com
# 2. Create a new project
# 3. Copy URL and keys from Settings > API
# 4. Run the SQL migration in Supabase SQL Editor
# 5. Add these env vars to Vercel Dashboard
# 6. Deploy!

# Security Notes:
# - Never commit .env.production to git
# - SUPABASE_SERVICE_KEY should be kept secret
# - Use different keys for staging/production